<div class="stats-grid">
    <div class="stat-card">
        <p class="stat-label">Inscripciones</p>
        <p class="stat-num">{{totalInscripciones}}</p>
        <p class="stat-sub">este mes</p>
    </div>
    <div class="stat-card">
        <p class="stat-label">Citas pendientes</p>
        <p class="stat-num">{{totalCitas}}</p>
        <p class="stat-sub">por atender</p>
    </div>
    <div class="stat-card">
        <p class="stat-label">Cobros pendientes</p>
        <p class="stat-num">{{totalCobros}}</p>
        <p class="stat-sub">sin pago</p>
    </div>
    <div class="stat-card">
        <p class="stat-label">Empleados activos</p>
        <p class="stat-num">{{totalEmpleados}}</p>
        <p class="stat-sub">en el sistema</p>
    </div>
</div>

<div class="tabla-wrap">
    <div class="tabla-header">
        <span>Inscripciones recientes</span>
    </div>
    <table>
        <thead>
            <tr>
                <th>Niño</th>
                <th>Representante</th>
                <th>Grado</th>
                <th>Tanda</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            {{#each inscripcionesRecientes}}
            <tr>
                <td>{{nombre_nino}} {{apellido_nino}}</td>
                <td>{{nombre_representante}} {{apellido_representante}}</td>
                <td>{{grado}}</td>
                <td>{{tanda}}</td>
                <td>
                    <span class="badge {{#if (eq estado 'pendiente')}}badge-pendiente{{else}}badge-aprobada{{/if}}">
                        {{estado}}
                    </span>
                </td>
            </tr>
            {{else}}
            <tr>
                <td colspan="5" class="text-center">No hay inscripciones registradas</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>