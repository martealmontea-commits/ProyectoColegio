<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Abhaya+Libre:wght@400;500;800&family=Arima:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" rel="stylesheet">
    <title>Iniciar Sesión</title>
    <link rel="stylesheet" href="/css/login.css">
</head>
<h1>LOGIN LIMPIO</h1>
<body>
<div class="login-wrapper">
    <div class="login-foto">
        <img src="/images/foto-colegio.png" alt="Colegio Padre Emiliano Tardif">
    </div>
    <div class="login-formulario">
        <div class="login-logo">
            <img src="/images/logo.png" alt="Logo" class="login-logo-img">
            <div class="login-logo-texto">
                <span class="login-nombre-colegio">Colegio Padre Emiliano Tardif</span>
                <span class="login-subtitulo">Sistema de Gestión Escolar</span>
            </div>
        </div>
        <h1 class="login-titulo">Iniciar Sesión</h1>
        <p class="login-desc">Ingrese sus credenciales para acceder al sistema</p>

        {{#if error}}
        <div class="alerta-error">{{error}}</div>
        {{/if}}

        <form action="/login" method="POST" class="login-form">
            <div class="campo">
                <label>Usuario</label>
                <div class="input-icono">
                    <i class="ti ti-user"></i>
                    <input type="text" name="usuario" placeholder="Ingrese su usuario" required>
                </div>
            </div>
            <div class="campo">
                <label>Contraseña</label>
                <div class="input-icono">
                    <i class="ti ti-lock"></i>
                    <input type="password" name="contrasena" placeholder="Ingrese su contraseña" required>
                </div>
            </div>
            <div class="campo">
                <label>Rol</label>
                <div class="input-icono">
                    <i class="ti ti-shield"></i>
                    <select name="rol">
                        <option value="">Seleccionar rol</option>
                        <option value="administrador">Administrador</option>
                        <option value="empleado">Empleado</option>
                    </select>
                </div>
            </div>
            <button type="submit" class="btn-ingresar">
                <i class="ti ti-login"></i> Ingresar
            </button>
        </form>
    </div>
</div>
</body>
</html>