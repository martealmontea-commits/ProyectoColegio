<div class="tabla-wrap">
    <div class="tabla-header">
        <span>Inscripciones registradas</span>
    </div>
    <table>
        <thead>
            <tr>
                <th>Niño</th>
                <th>Representante</th>
                <th>Matrícula</th>
                <th>Grado</th>
                <th>Tanda</th>
                <th>Empleado</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            {{#each inscripciones}}
            <tr>
                <td>{{nombre_nino}} {{apellido_nino}}</td>
                <td>{{nombre_representante}} {{apellido_representante}}</td>
                <td>{{matricula}}</td>
                <td>{{grado}}</td>
                <td>{{tanda}}</td>
                <td>{{nombre_empleado}} {{apellido_empleado}}</td>
                <td>
                    <span class="badge {{#if (eq estado 'pendiente')}}badge-pendiente{{else if (eq estado 'aprobada')}}badge-aprobada{{else}}badge-pendiente{{/if}}">
                        {{estado}}
                    </span>
                </td>
            </tr>
            {{else}}
            <tr>
                <td colspan="7" class="text-center">No hay inscripciones registradas</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>

<div class="form-wrap">
    <div class="form-encabezado">
        <span>Nueva inscripción</span>
    </div>
    <div class="form-body">
        <form action="/api/inscripcion" method="POST">
            <div class="seccion">
                <div class="seccion-titulo">
                    <i class="ti ti-user"></i> Datos del representante
                </div>
                <div class="grid3">
                    <div class="campo">
                        <label>Nombre</label>
                        <input type="text" name="nombre_rep" placeholder="Nombre" required>
                    </div>
                    <div class="campo">
                        <label>Apellido</label>
                        <input type="text" name="apellido_rep" placeholder="Apellido" required>
                    </div>
                    <div class="campo">
                        <label>Cédula</label>
                        <input type="text" name="cedula_rep" placeholder="000-0000000-0" required>
                    </div>
                </div>
                <div class="grid3">
                    <div class="campo">
                        <label>Teléfono</label>
                        <input type="text" name="telefono_rep" placeholder="809-000-0000" required>
                    </div>
                    <div class="campo">
                        <label>Teléfono laboral</label>
                        <input type="text" name="tel_laboral_rep" placeholder="809-000-0000">
                    </div>
                    <div class="campo">
                        <label>Correo</label>
                        <input type="email" name="correo_rep" placeholder="correo@email.com" required>
                    </div>
                </div>
                <div class="grid3">
                    <div class="campo">
                        <label>Fecha de nacimiento</label>
                        <input type="date" name="fecha_nac_rep" required>
                    </div>
                    <div class="campo">
                        <label>Ocupación</label>
                        <input type="text" name="ocupacion_rep" placeholder="Ocupación">
                    </div>
                    <div class="campo">
                        <label>Lugar de trabajo</label>
                        <input type="text" name="lugar_trabajo_rep" placeholder="Lugar de trabajo">
                    </div>
                </div>
            </div>

            <div class="seccion">
                <div class="seccion-titulo">
                    <i class="ti ti-mood-kid"></i> Datos del niño
                </div>
                <div class="grid3">
                    <div class="campo">
                        <label>Nombre</label>
                        <input type="text" name="nombre_nino" placeholder="Nombre" required>
                    </div>
                    <div class="campo">
                        <label>Apellido</label>
                        <input type="text" name="apellido_nino" placeholder="Apellido" required>
                    </div>
                    <div class="campo">
                        <label>Fecha de nacimiento</label>
                        <input type="date" name="fecha_nac_nino" required>
                    </div>
                </div>
                <div class="grid3">
                    <div class="campo">
                        <label>Sexo</label>
                        <select name="sexo_nino">
                            <option value="Masculino">Masculino</option>
                            <option value="Femenino">Femenino</option>
                        </select>
                    </div>
                    <div class="campo">
                        <label>Lugar de nacimiento</label>
                        <input type="text" name="lugar_nac_nino" placeholder="Ciudad, país" required>
                    </div>
                    <div class="campo">
                        <label>Nacionalidad</label>
                        <input type="text" name="nacionalidad_nino" placeholder="Nacionalidad" required>
                    </div>
                </div>
                <div class="grid3">
                    <div class="campo">
                        <label>Matrícula</label>
                        <input type="text" name="matricula" placeholder="Matrícula" required>
                    </div>
                    <div class="campo">
                        <label>Grado</label>
                        <select name="grado">
                            <option value="Kinder">Kinder</option>
                            <option value="1ro">1ro</option>
                            <option value="2do">2do</option>
                            <option value="3ro">3ro</option>
                            <option value="4to">4to</option>
                            <option value="5to">5to</option>
                            <option value="6to">6to</option>
                        </select>
                    </div>
                    <div class="campo">
                        <label>Tanda</label>
                        <select name="tanda">
                            <option value="Matutina">Matutina</option>
                            <option value="Vespertina">Vespertina</option>
                        </select>
                    </div>
                </div>
                <div class="grid2">
                    <div class="campo">
                        <label>¿Ha asistido a otro centro?</label>
                        <div class="radio-group">
                            <label><input type="radio" name="ha_asistido" value="1"> Sí</label>
                            <label><input type="radio" name="ha_asistido" value="0" checked> No</label>
                        </div>
                    </div>
                    <div class="campo">
                        <label>Motivación</label>
                        <input type="text" name="motivacion" placeholder="¿Por qué eligió este colegio?">
                    </div>
                </div>
            </div>

            <div class="seccion">
                <div class="seccion-titulo">
                    <i class="ti ti-heart-rate-monitor"></i> Salud y hábitos
                </div>
                <div class="grid3">
                    <div class="campo">
                        <label>Tipo de sangre</label>
                        <input type="text" name="tipo_sangre" placeholder="A+, O-, etc" required>
                    </div>
                    <div class="campo">
                        <label>Alergias</label>
                        <input type="text" name="alergias" placeholder="Si aplica">
                    </div>
                    <div class="campo">
                        <label>Condiciones médicas</label>
                        <input type="text" name="condiciones_medicas" placeholder="Si aplica">
                    </div>
                </div>
                <div class="grid2">
                    <div class="campo">
                        <label>Medicamentos</label>
                        <input type="text" name="medicamentos" placeholder="Si aplica">
                    </div>
                    <div class="campo">
                        <label>Discapacidad</label>
                        <input type="text" name="discapacidad" placeholder="Si aplica">
                    </div>
                </div>
                <div class="grid3">
                    <div class="campo">
                        <label>Hora de sueño</label>
                        <input type="time" name="hora_suenio" required>
                    </div>
                    <div class="campo">
                        <label>Hora de despertar</label>
                        <input type="time" name="hora_despertar" required>
                    </div>
                    <div class="campo">
                        <label>Actividad favorita</label>
                        <input type="text" name="actividad_favorita" placeholder="Actividad">
                    </div>
                </div>
                <div class="grid3">
                    <div class="campo">
                        <label>¿Toma siesta?</label>
                        <div class="radio-group">
                            <label><input type="radio" name="toma_siesta" value="1"> Sí</label>
                            <label><input type="radio" name="toma_siesta" value="0" checked> No</label>
                        </div>
                    </div>
                    <div class="campo">
                        <label>¿Duerme solo?</label>
                        <div class="radio-group">
                            <label><input type="radio" name="duerme_solo" value="1"> Sí</label>
                            <label><input type="radio" name="duerme_solo" value="0" checked> No</label>
                        </div>
                    </div>
                    <div class="campo">
                        <label>¿Con quién duerme?</label>
                        <input type="text" name="duerme_con" placeholder="Si aplica">
                    </div>
                </div>
            </div>

            <input type="hidden" name="id_empleado" value="{{usuario.id}}">
            <input type="hidden" name="id_departamento" value="1">
            <input type="hidden" name="estado_inscripcion" value="pendiente">

            <div class="form-footer">
                <button type="button" class="btn-cancelar" onclick="window.location='/admin'">Cancelar</button>
                <button type="submit" class="btn-guardar">Guardar inscripción</button>
            </div>
        </form>
    </div>
</div>